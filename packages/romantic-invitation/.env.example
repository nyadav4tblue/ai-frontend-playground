# Supabase configuration for the romantic-invitation package
# Get these from: https://supabase.com → Your Project → Settings → API

# Project URL - found under "Project URL" in Supabase Settings
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon (Public) Key - found under "anon (public)" in Supabase Settings
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Setup Instructions:
# 1. Create a Supabase project at https://supabase.com
# 2. Copy your Project URL and Anon Key into the variables above
# 3. Run the database migrations in ./supabase/migrations/
#    See ./supabase/README.md for detailed setup instructions
# 4. Replace this file with .env.local (git-ignored) with your actual credentials
